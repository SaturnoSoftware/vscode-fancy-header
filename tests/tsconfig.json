{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "baseUrl": "..",
    "outDir": "../out",
    "types": ["node"]
  },
  "include": ["./**/*.test.ts", "../src/**/*.ts", "../libs/**/*.ts"],
  "exclude": ["../node_modules"]
}
